<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Categories</h1>
    <% if current_user&.admin? %>
      <%= link_to new_category_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        New Category
      <% end %>
    <% end %>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-md">
    <ul class="divide-y divide-gray-200">
      <% @categories.each do |category| %>
        <li>
          <%= link_to category_path(category), class: "block hover:bg-gray-50" do %>
            <div class="px-4 py-4 sm:px-6">
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <div class="h-10 w-10 rounded-full flex items-center justify-center text-white" style="background-color: <%= category.color %>">
                    <% if category.respond_to?(:icon) && category.icon.present? && category.icon_emoji %>
                      <span class="text-lg"><%= category.icon_emoji %></span>
                    <% else %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M17.707 9.293a1 1 0 010 1.414l-7 7a1 1 0 01-1.414 0l-7-7A.997.997 0 012 10V5a3 3 0 013-3h5c.256 0 .512.098.707.293l7 7zM5 6a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                      </svg>
                    <% end %>
                  </div>
                  <p class="ml-3 text-lg font-medium text-gray-900"><%= category.name %></p>
                </div>
                <div class="flex items-center">
                  <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    <%= pluralize(category.posts_count, 'post') %>
                  </span>
                  <% if current_user&.admin? %>
                    <div class="ml-4 flex-shrink-0 flex">
                      <%= link_to edit_category_path(category), class: "mr-2 text-indigo-600 hover:text-indigo-900" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                          <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                        </svg>
                      <% end %>
                      <%= button_to category_path(category), method: :delete, class: "text-red-600 hover:text-red-900", data: { confirm: "Are you sure you want to delete this category?" } do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
              <% if category.description.present? %>
                <div class="mt-2 text-sm text-gray-500">
                  <%= truncate(category.description, length: 150) %>
                </div>
              <% end %>
            </div>
          <% end %>
        </li>
      <% end %>

      <% if @categories.empty? %>
        <li class="px-4 py-6 sm:px-6 text-center text-gray-500">
          No categories found.
          <% if current_user&.admin? %>
            <%= link_to "Create the first category", new_category_path, class: "text-indigo-600 hover:text-indigo-900" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
