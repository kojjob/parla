<%= form_with(model: category) do |form| %>
  <% if category.errors.any? %>
    <div class="bg-red-50 text-red-500 p-4 rounded-md mb-6">
      <h2><%= pluralize(category.errors.count, "error") %> prohibited this category from being saved:</h2>
      <ul class="list-disc pl-5 mt-2">
        <% category.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-6">
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      <p class="mt-1 text-sm text-gray-500">Brief description of the category (optional)</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :color, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1 flex items-center">
          <div class="h-8 w-8 rounded-full mr-3 border border-gray-300" id="color-preview" style="background-color: <%= category.color || '#3B82F6' %>"></div>
          <%= form.color_field :color, value: category.color || "#3B82F6", class: "rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", onchange: "document.getElementById('color-preview').style.backgroundColor = this.value" %>
        </div>
        <p class="mt-1 text-sm text-gray-500">Choose a color for the category</p>
      </div>

      <div>
        <%= form.label :icon, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.select :icon,
              [
                ['📚 Books', 'books'],
                ['💻 Technology', 'technology'],
                ['🍔 Food', 'food'],
                ['✈️ Travel', 'travel'],
                ['🏋️ Fitness', 'fitness'],
                ['🎮 Gaming', 'gaming'],
                ['🎬 Movies', 'movies'],
                ['🎵 Music', 'music'],
                ['📱 Mobile', 'mobile'],
                ['🏠 Home', 'home'],
                ['👕 Fashion', 'fashion'],
                ['💼 Business', 'business'],
                ['🎨 Art', 'art'],
                ['📰 News', 'news'],
                ['⚽ Sports', 'sports'],
                ['🌿 Nature', 'nature'],
                ['🔬 Science', 'science'],
                ['🧠 Education', 'education']
              ],
              { include_blank: 'Select an icon (optional)' },
              { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" }
          %>
        </div>
        <p class="mt-1 text-sm text-gray-500">Choose an icon for the category</p>
      </div>
    </div>

    <div class="flex justify-end">
      <%= link_to "Cancel", categories_path, class: "mr-3 inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none" %>
      <%= form.submit class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none" %>
    </div>
  </div>
<% end %>
