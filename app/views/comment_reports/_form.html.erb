<%= form_with(model: [comment, report], local: true, id: "report_form") do |form| %>
  <% if report.errors.any? %>
    <div class="bg-red-50 text-red-500 p-3 rounded-md mb-4">
      <h2 class="text-sm font-medium"><%= pluralize(report.errors.count, "error") %> prohibited this report from being saved:</h2>
      <ul class="list-disc list-inside mt-1 text-xs">
        <% report.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :reason, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.select :reason, CommentReport::REPORT_REASONS.map { |r| [r.humanize, r] }, 
                   { include_blank: "Select a reason" }, 
                   { class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" } %>
  </div>

  <div class="mb-4">
    <%= form.label :details, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :details, rows: 3, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Please provide additional details about this report..." %>
  </div>

  <div class="flex justify-end space-x-3">
    <%= link_to "Cancel", "#", class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none", data: { action: "click->modal#close" } %>
    <%= form.submit "Submit Report", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none" %>
  </div>
<% end %>
