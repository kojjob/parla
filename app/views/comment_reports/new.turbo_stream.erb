<%= turbo_stream.replace "modal" do %>
  <div id="modal" class="fixed inset-0 z-50 overflow-y-auto" data-controller="modal">
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
      <div class="fixed inset-0 transition-opacity" aria-hidden="true" data-action="click->modal#close">
        <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
      </div>

      <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

      <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
        <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
          <div class="sm:flex sm:items-start">
            <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
              <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">
                Report Comment
              </h3>
              
              <div class="mb-4 p-3 bg-gray-50 rounded-md">
                <h4 class="text-sm font-medium text-gray-700 mb-1">Comment by <%= @comment.user.name %></h4>
                <div class="text-sm text-gray-600">
                  <% if @comment.content.present? %>
                    <p><%= truncate(@comment.content, length: 150) %></p>
                  <% elsif @comment.has_rich_content? %>
                    <%= @comment.rich_content %>
                  <% end %>
                  
                  <% if @comment.has_attachment? %>
                    <p class="mt-1 text-xs text-gray-500">[This comment includes an attachment]</p>
                  <% end %>
                </div>
              </div>
              
              <%= render "form", comment: @comment, report: @report %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
