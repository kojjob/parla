<%# Compact Post Card - Small card with image on left for sidebar or list views %>
<article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border border-gray-100">
  <a href="<%= post_path(post) %>" class="block group">
    <div class="flex">
      <% if post.cover_image.attached? %>
        <div class="flex-shrink-0 w-24 h-24 sm:w-32 sm:h-32 relative overflow-hidden">
          <%= image_tag post.cover_image.variant(resize_to_fill: [128, 128]), 
              class: "w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300",
              alt: post.title,
              loading: "lazy" %>
        </div>
      <% end %>
      
      <div class="<%= post.cover_image.attached? ? 'ml-3' : '' %> flex-1 p-3">
        <% if post.category.present? %>
          <span class="inline-block text-xs font-medium text-blue-600 mb-1"><%= post.category.name %></span>
        <% end %>
        
        <h4 class="text-sm sm:text-base font-semibold text-gray-900 group-hover:text-blue-600 transition-colors duration-200 line-clamp-2 mb-1"><%= post.title %></h4>
        
        <div class="text-xs text-gray-500 mt-1">
          <%= time_ago_in_words(post.created_at) %> ago
          
          <% if post.respond_to?(:comments_count) && post.comments_count.present? && post.comments_count > 0 %>
            <span class="mx-1">•</span>
            <span><%= pluralize(post.comments_count, 'comment') %></span>
          <% end %>
        </div>
      </div>
    </div>
  </a>
</article>
