<%# posts/show.html.erb %>
<% content_for :title, @post.title %>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8" data-controller="post-show">
  <% if notice.present? %>
    <div class="mb-6 animate-fade-in" id="notice">
      <div class="rounded-lg bg-green-50 p-4 border-l-4 border-green-500 shadow-sm">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-green-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm font-medium text-green-700"><%= notice %></p>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <nav class="mb-8">
    <%= link_to posts_path, class: "text-gray-500 hover:text-gray-700 flex items-center text-sm font-medium" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
      </svg>
      Back to posts
    <% end %>
  </nav>

  <!-- Hero section with cover image -->
  <div class="relative overflow-hidden rounded-2xl mb-10 shadow-lg">
    <div class="aspect-[16/9] w-full">
      <% if @post.cover_image.attached? %>
        <%= image_tag @post.cover_image.variant(resize_to_limit: [1200, 675]), class: "w-full h-full object-cover" %>
      <% elsif @post.gallery_images.attached? && @post.gallery_images.first.present? %>
        <!-- Use first gallery image as cover if no cover image -->
        <%= image_tag @post.gallery_images.first.variant(resize_to_limit: [1200, 675]), class: "w-full h-full object-cover" %>
      <% else %>
        <div class="w-full h-full bg-gradient-to-r from-indigo-500 to-purple-600 flex items-center justify-center">
          <div class="text-center text-white p-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-4 opacity-75" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <h2 class="text-xl font-bold"><%= @post.title %></h2>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Overlay gradient for better text visibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent pointer-events-none"></div>

    <!-- Category and gallery info positioned on the image -->
    <div class="absolute bottom-6 left-6 right-6 flex justify-between items-end">
      <div>
        <% if @post.category.present? %>
          <%= link_to category_path(@post.category), class: "inline-flex items-center px-3 py-1 rounded-md text-sm font-medium text-white uppercase shadow-sm", style: "background-color: #{@post.category.color}" do %>
            <%= @post.category.name %>
          <% end %>
        <% end %>

        <% if @post.respond_to?(:secondary_category) && @post.secondary_category.present? %>
          <span class="ml-2 inline-flex items-center px-3 py-1 rounded-md text-sm font-medium bg-purple-600 text-white uppercase shadow-sm">
            <%= @post.secondary_category %>
          </span>
        <% end %>
      </div>

      <% if @post.gallery_images.attached? && @post.gallery_images.any? %>
        <div class="bg-black/50 text-white text-sm px-3 py-1 rounded-full shadow-sm flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <%= pluralize(@post.gallery_images.count, 'photo') %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Main content area -->
  <div class="flex flex-col lg:flex-row gap-12">
    <!-- Left column - Main content -->
    <div class="w-full lg:w-2/3">
      <!-- Post header -->
      <div class="mb-8">
        <h1 class="font-bold text-4xl text-gray-900 mb-6"><%= @post.title %></h1>

        <!-- Author & date row -->
        <div class="flex items-center mb-8">
          <!-- Author avatar -->
          <div class="mr-4">
            <% if @post.respond_to?(:author) && @post.author && @post.author.respond_to?(:avatar) && @post.author.avatar.attached? %>
              <div class="h-12 w-12 rounded-full overflow-hidden">
                <%= image_tag @post.author.avatar, class: "h-full w-full object-cover" %>
              </div>
            <% else %>
              <div class="h-12 w-12 rounded-full overflow-hidden bg-gray-200 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            <% end %>
          </div>

          <!-- Author info and date -->
          <div>
            <div class="text-gray-900 font-medium">
              <% if @post.respond_to?(:author) && @post.author %>
                <%= @post.author.name %>
              <% else %>
                John Doe
              <% end %>
            </div>
            <div class="text-gray-500 text-sm flex items-center">
              <span><%= @post.created_at.strftime("%B %d, %Y") %></span>
              <span class="mx-2">•</span>
              <span><%= @post.respond_to?(:reading_time) ? "#{@post.reading_time} min read" : "4 min read" %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Main post content -->
      <div class="prose prose-lg max-w-none">
        <%= @post.body %>
      </div>

      <!-- Gallery images -->
      <% if @post.gallery_images.attached? && @post.gallery_images.any? %>
        <div class="my-12">
          <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Photo Gallery <span class="text-gray-500 text-sm font-normal ml-2">(<%= @post.gallery_images.count %> images)</span>
          </h3>

          <!-- Gallery grid with masonry layout -->
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 auto-rows-auto" data-controller="lightbox">
            <% @post.gallery_images.each_with_index do |image, index| %>
              <%
                # Determine if this image should span multiple columns/rows for visual interest
                # First image is larger, then every 5th image
                is_featured = index == 0 || index % 5 == 0
                grid_class = is_featured ? "col-span-2 row-span-2" : ""
              %>
              <div class="<%= grid_class %> relative group rounded-lg overflow-hidden bg-gray-100 shadow-sm hover:shadow-md transition-shadow duration-300">
                <%= link_to image_tag(image.variant(resize_to_fill: is_featured ? [800, 600] : [400, 400]), class: "w-full h-full object-cover"), url_for(image), class: "block", data: { action: "click->lightbox#open", lightbox_target: "image" } %>
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end justify-start p-4">
                  <button type="button" class="text-white bg-black/30 p-2 rounded-full hover:bg-indigo-600 transition-colors" data-action="click->lightbox#open">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                    </svg>
                  </button>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Social sharing section -->
      <div class="my-12 border-t border-b border-gray-100 py-8">
        <div class="flex flex-col sm:flex-row justify-between items-center">
          <!-- Copy URL section -->
          <div class="flex items-center mb-4 sm:mb-0">
            <label class="text-gray-700 font-medium mr-3">Share Article</label>
            <div class="relative flex-grow max-w-md">
              <input type="text" value="<%= request.original_url %>" readonly class="py-2 px-3 block w-full border border-gray-300 rounded-md text-sm bg-gray-50">
              <button data-action="post-show#copyToClipboard" class="absolute inset-y-0 right-0 flex items-center px-3 rounded-r-md border border-l-0 border-gray-300 bg-gray-50 hover:bg-gray-100">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M8 2a1 1 0 000 2h2a1 1 0 100-2H8z" />
                  <path d="M3 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v6h-4.586l1.293-1.293a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L10.414 13H15v3a2 2 0 01-2 2H5a2 2 0 01-2-2V5zM15 11h2a1 1 0 110 2h-2v-2z" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Social media sharing -->
          <div class="flex space-x-2">
            <a href="https://www.facebook.com/sharer/sharer.php?u=<%= CGI.escape(request.original_url) %>" target="_blank" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-blue-600 hover:bg-blue-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z" />
              </svg>
            </a>
            <a href="https://twitter.com/intent/tweet?url=<%= CGI.escape(request.original_url) %>&text=<%= CGI.escape(@post.title) %>" target="_blank" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-blue-400 hover:bg-blue-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z" />
              </svg>
            </a>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= CGI.escape(request.original_url) %>" target="_blank" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-blue-700 hover:bg-blue-800 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z" />
              </svg>
            </a>
            <a href="mailto:?subject=<%= CGI.escape(@post.title) %>&body=<%= CGI.escape("Check out this article: #{request.original_url}") %>" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-green-500 hover:bg-green-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 20 20" fill="currentColor">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
              </svg>
            </a>
            <a href="https://api.whatsapp.com/send?text=<%= CGI.escape("#{@post.title} #{request.original_url}") %>" target="_blank" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-green-600 hover:bg-green-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Tags section -->
      <% if @post.respond_to?(:tags) && @post.tags.present? %>
        <div class="mb-12">
          <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Tags</h3>
          <div class="flex flex-wrap gap-2">
            <% @post.tags_list.each do |tag| %>
              <%= link_to posts_path(tag: tag), class: "inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800 hover:bg-gray-200 transition-colors" do %>
                <%= tag %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Author bio section -->
      <% if @post.respond_to?(:author) && @post.author %>
        <div class="bg-gray-50 rounded-xl p-6 mb-12">
          <div class="flex flex-col sm:flex-row items-center sm:items-start">
            <!-- Author avatar -->
            <div class="mb-4 sm:mb-0 sm:mr-6">
              <% if @post.author.respond_to?(:avatar) && @post.author.avatar.attached? %>
                <div class="h-20 w-20 rounded-full overflow-hidden">
                  <%= image_tag @post.author.avatar, class: "h-full w-full object-cover" %>
                </div>
              <% else %>
                <div class="h-20 w-20 rounded-full overflow-hidden bg-gray-200 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
              <% end %>
            </div>

            <!-- Author details -->
            <div class="text-center sm:text-left">
              <h3 class="text-xl font-bold text-gray-900 mb-2">
                <%= @post.author.name %>
              </h3>
              <p class="text-gray-600 mb-4">
                <% if @post.author.respond_to?(:bio) && @post.author.bio.present? %>
                  <%= @post.author.bio %>
                <% else %>
                  I am so happy, my dear friend, so absorbed in the exquisite sense of mere tranquil existence, that I neglect my talents.
                <% end %>
              </p>

              <!-- Author social links -->
              <div class="flex justify-center sm:justify-start space-x-3">
                <% if @post.author.respond_to?(:twitter) && @post.author.twitter.present? %>
                  <a href="<%= @post.author.twitter %>" target="_blank" class="text-blue-400 hover:text-blue-600 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z" />
                    </svg>
                  </a>
                <% else %>
                  <a href="#" class="text-blue-400 hover:text-blue-600 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z" />
                    </svg>
                  </a>
                <% end %>

                <% if @post.author.respond_to?(:facebook) && @post.author.facebook.present? %>
                  <a href="<%= @post.author.facebook %>" target="_blank" class="text-blue-600 hover:text-blue-800 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z" />
                    </svg>
                  </a>
                <% else %>
                  <a href="#" class="text-blue-600 hover:text-blue-800 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z" />
                    </svg>
                  </a>
                <% end %>

                <% if @post.author.respond_to?(:instagram) && @post.author.instagram.present? %>
                  <a href="<%= @post.author.instagram %>" target="_blank" class="text-pink-600 hover:text-pink-800 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                    </svg>
                  </a>
                <% else %>
                  <a href="#" class="text-pink-600 hover:text-pink-800 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                    </svg>
                  </a>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Comments section -->
      <%= render "comments/comments_section_stimulus" %>

      <!-- Post navigation (Next/Previous) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        <% if @post.previous_post.present? %>
          <%= link_to post_path(@post.previous_post), class: "group flex items-center p-4 border border-gray-200 rounded-lg hover:border-gray-300 hover:bg-gray-50 transition-all" do %>
            <div class="mr-4 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400 group-hover:text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
            </div>
            <div>
              <div class="text-sm text-gray-500 mb-1">Previous article</div>
              <h4 class="text-base font-medium text-gray-900 group-hover:text-indigo-600 line-clamp-2"><%= @post.previous_post.title %></h4>
            </div>
          <% end %>
        <% else %>
          <div class="flex items-center p-4 border border-gray-100 rounded-lg bg-gray-50">
            <div class="mr-4 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
            </div>
            <div>
              <div class="text-sm text-gray-400 mb-1">Previous article</div>
              <h4 class="text-base font-medium text-gray-400">No older articles</h4>
            </div>
          </div>
        <% end %>

        <% if @post.next_post.present? %>
          <%= link_to post_path(@post.next_post), class: "group flex items-center justify-end p-4 border border-gray-200 rounded-lg hover:border-gray-300 hover:bg-gray-50 transition-all" do %>
            <div class="text-right">
              <div class="text-sm text-gray-500 mb-1">Next article</div>
              <h4 class="text-base font-medium text-gray-900 group-hover:text-indigo-600 line-clamp-2"><%= @post.next_post.title %></h4>
            </div>
            <div class="ml-4 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400 group-hover:text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          <% end %>
        <% else %>
          <div class="flex items-center justify-end p-4 border border-gray-100 rounded-lg bg-gray-50">
            <div class="text-right">
              <div class="text-sm text-gray-400 mb-1">Next article</div>
              <h4 class="text-base font-medium text-gray-400">No newer articles</h4>
            </div>
            <div class="ml-4 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Action buttons -->
      <div class="flex flex-wrap gap-3 mb-10">
        <% if user_signed_in? && @post.user == current_user %>
          <%= link_to edit_post_path(@post), class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50 transition-all duration-150" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
            Edit post
          <% end %>

          <%= button_to @post, method: :delete, class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-medium text-red-600 shadow-sm ring-1 ring-gray-300 hover:bg-red-50 transition-all duration-150", data: { turbo_confirm: "Are you sure you want to delete this post?" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            Delete
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Right sidebar -->
    <div class="w-full lg:w-1/3">
      <!-- Related Articles -->
      <div class="mb-10">
        <h3 class="text-lg font-bold text-gray-900 border-b border-gray-200 pb-3 mb-4">Related Posts</h3>
        <div class="space-y-6">
          <% if @related_posts.any? %>
            <% @related_posts.each do |post| %>
              <div class="flex items-start group">
                <div class="flex-shrink-0 mr-4">
                  <%= link_to post_path(post) do %>
                    <% if post.cover_image.attached? %>
                      <%= image_tag post.cover_image.variant(resize_to_fill: [100, 100]),
                          class: "w-20 h-20 object-cover rounded-md group-hover:opacity-90 transition-opacity",
                          alt: post.title,
                          loading: "lazy" %>
                    <% elsif post.gallery_images.attached? && post.gallery_images.first.present? %>
                      <%= image_tag post.gallery_images.first.variant(resize_to_fill: [100, 100]),
                          class: "w-20 h-20 object-cover rounded-md group-hover:opacity-90 transition-opacity",
                          alt: post.title,
                          loading: "lazy" %>
                    <% else %>
                      <div class="w-20 h-20 bg-gradient-to-br from-gray-200 to-gray-300 rounded-md flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                    <% end %>
                  <% end %>
                </div>
                <div>
                  <h4 class="font-medium text-gray-900 group-hover:text-indigo-600 transition-colors mb-1 text-base">
                    <%= link_to post.title, post_path(post) %>
                  </h4>
                  <div class="text-xs text-gray-500 mb-1"><%= post.created_at.strftime("%B %d, %Y") %></div>
                  <div class="flex items-center space-x-4">
                    <% if post.category.present? %>
                      <span class="inline-flex items-center text-xs" style="color: <%= post.category.color || '#3B82F6' %>">
                        <%= post.category.name %>
                      </span>
                    <% end %>
                    <% if post.respond_to?(:reading_time) %>
                      <span class="inline-flex items-center text-xs text-gray-500">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                        </svg>
                        <%= post.reading_time %> min read
                      </span>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-8 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto text-gray-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <p class="text-gray-500 text-sm">No related posts found</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Categories -->
      <div class="mb-10">
        <h3 class="text-lg font-bold text-gray-900 border-b border-gray-200 pb-3 mb-4">Categories</h3>
        <div class="space-y-2">
          <% Category.order(posts_count: :desc).limit(5).each do |category| %>
            <%= link_to category_path(category), class: "block p-3 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors" do %>
              <div class="flex justify-between items-center">
                <div class="flex items-center">
                  <div class="h-4 w-4 rounded-full mr-2" style="background-color: <%= category.color %>"></div>
                  <span class="font-medium text-gray-900"><%= category.name %></span>
                </div>
                <span class="bg-gray-200 text-gray-700 text-xs rounded-full px-2 py-1"><%= pluralize(category.posts_count, 'post') %></span>
              </div>
            <% end %>
          <% end %>

          <% if Category.count > 5 %>
            <%= link_to categories_path, class: "mt-2 text-center block text-sm text-indigo-600 hover:text-indigo-800" do %>
              View all categories
            <% end %>
          <% end %>

          <% if Category.none? %>
            <div class="text-center p-4 text-gray-500 text-sm">
              No categories yet
            </div>
          <% end %>
        </div>
      </div>

      <!-- Popular Tags -->
      <div class="mb-10">
        <h3 class="text-lg font-bold text-gray-900 border-b border-gray-200 pb-3 mb-4">Popular Tags</h3>
        <div class="flex flex-wrap gap-2">
          <% popular_tags = Post.popular_tags(12) %>
          <% if popular_tags.any? %>
            <% popular_tags.each do |tag| %>
              <%= link_to posts_path(tag: tag), class: "inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800 hover:bg-gray-200 transition-colors" do %>
                <%= tag %>
                <% tag_count = Post.published.where("tags LIKE ?", "%#{tag}%").count %>
                <% if tag_count > 0 %>
                  <span class="ml-1 text-xs text-gray-500">(<%= tag_count %>)</span>
                <% end %>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-500 italic">No tags found</p>
          <% end %>
        </div>
      </div>

      <!-- Newsletter Signup -->
      <div class="bg-gradient-to-br from-indigo-600 to-purple-600 rounded-lg p-6 text-white">
        <h3 class="text-xl font-bold mb-3">Subscribe to Our Newsletter</h3>
        <p class="text-white/80 mb-4">Get the latest posts delivered right to your inbox.</p>
        <form class="space-y-3">
          <div>
            <input type="email" placeholder="Your email address" class="w-full px-4 py-2 rounded-md text-gray-900 text-sm">
          </div>
          <button type="submit" class="w-full bg-white text-indigo-600 font-medium py-2 px-4 rounded-md hover:bg-gray-100 transition-colors">
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes fadeIn {
    0% { opacity: 0; transform: translateY(-10px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }

  .prose {
    max-width: 65ch;
    color: #374151;
  }

  .prose img {
    border-radius: 0.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  .prose h2 {
    font-weight: 700;
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #1f2937;
  }

  .prose h3 {
    font-weight: 600;
    font-size: 1.25rem;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: #1f2937;
  }

  .prose p {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }

  .prose a {
    color: #2563eb;
    text-decoration: underline;
    font-weight: 500;
  }

  .prose blockquote {
    font-style: italic;
    color: #4b5563;
    border-left-width: 4px;
    border-left-color: #e5e7eb;
    padding-left: 1rem;
  }

  .prose code {
    color: #111827;
    font-weight: 600;
    font-size: 0.875em;
  }

  .prose pre {
    color: #e5e7eb;
    background-color: #1f2937;
    overflow-x: auto;
    font-size: 0.875em;
    line-height: 1.7142857;
    margin-top: 1.7142857em;
    margin-bottom: 1.7142857em;
    border-radius: 0.375rem;
    padding: 0.8571429em 1.1428571em;
  }
</style>