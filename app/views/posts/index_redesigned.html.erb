<%# Posts Index - Modern News/Blog Layout %>
<% content_for :title, "Parla - News & Articles" %>

<div class="bg-gray-50 min-h-screen">
  <%# Hero Section with Featured Post %>
  <section class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Featured Story</h1>
        <%= link_to "View all stories", "#featured-posts", class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center" %>
      </div>

      <% if @main_post.present? %>
        <%= render 'featured_post_card', post: @main_post %>
      <% else %>
        <%= render 'empty_state', 
          title: "No featured stories yet", 
          message: "Check back soon for featured content",
          show_button: current_user.present?,
          button_path: new_post_path,
          button_text: "Create a post" %>
      <% end %>
    </div>
  </section>

  <%# Main Content Area %>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="lg:grid lg:grid-cols-3 lg:gap-8">
      <%# Main Content - 2/3 width %>
      <div class="lg:col-span-2">
        <%# Latest Posts Section %>
        <section id="featured-posts" class="mb-12">
          <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-bold text-gray-900">Latest Posts</h2>
            
            <div class="flex items-center space-x-2">
              <span class="text-sm text-gray-500">Sort by:</span>
              <%= link_to "Newest", posts_path(sort: 'newest'), class: "text-sm #{params[:sort] != 'oldest' ? 'font-medium text-indigo-600' : 'text-gray-500 hover:text-gray-700'}" %>
              <span class="text-gray-300">|</span>
              <%= link_to "Oldest", posts_path(sort: 'oldest'), class: "text-sm #{params[:sort] == 'oldest' ? 'font-medium text-indigo-600' : 'text-gray-500 hover:text-gray-700'}" %>
            </div>
          </div>

          <% if @paginated_posts.any? %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% @paginated_posts.each do |post| %>
                <%= render 'standard_post_card', post: post %>
              <% end %>
            </div>

            <%# Pagination %>
            <div class="mt-8 flex justify-center">
              <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
            </div>
          <% else %>
            <%= render 'empty_state', 
              title: "No posts found", 
              message: "There are no posts matching your criteria",
              show_button: current_user.present?,
              button_path: new_post_path,
              button_text: "Create a post" %>
          <% end %>
        </section>

        <%# Category Sections %>
        <% @categories.each do |category| %>
          <% category_posts = @posts_by_category[category.id] %>
          <% if category_posts.present? && category_posts.any? %>
            <section class="mb-12 pb-8 border-b border-gray-200">
              <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-bold text-gray-900" style="color: <%= category.color || '#3b82f6' %>">
                  <%= category.name %>
                </h2>
                <%= link_to "View all", posts_path(category_id: category.id), class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center" %>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% category_posts.each do |post| %>
                  <%= render 'standard_post_card', post: post %>
                <% end %>
              </div>
            </section>
          <% end %>
        <% end %>
      </div>

      <%# Sidebar - 1/3 width %>
      <div class="mt-12 lg:mt-0">
        <%# Search Box %>
        <div class="bg-white rounded-lg shadow-sm p-6 mb-8">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Search Posts</h3>
          <form action="<%= posts_path %>" method="get" class="flex">
            <input type="text" name="q" placeholder="Search for posts..." class="flex-1 min-w-0 block w-full px-3 py-2 rounded-md border border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" value="<%= params[:q] %>">
            <button type="submit" class="ml-3 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
          </form>
        </div>

        <%# Categories List %>
        <div class="bg-white rounded-lg shadow-sm p-6 mb-8">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Categories</h3>
          <div class="space-y-2">
            <% @categories.each do |category| %>
              <%= link_to posts_path(category_id: category.id), class: "flex items-center justify-between group" do %>
                <span class="text-gray-600 group-hover:text-indigo-600 transition-colors duration-200"><%= category.name %></span>
                <span class="bg-gray-100 text-gray-600 text-xs font-medium px-2 py-0.5 rounded-full"><%= category.posts_count || 0 %></span>
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Recent Posts %>
        <div class="bg-white rounded-lg shadow-sm p-6 mb-8">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Recent Posts</h3>
          <div class="space-y-4">
            <% @recent_posts.each do |post| %>
              <%= render 'compact_post_card', post: post %>
            <% end %>
          </div>
        </div>

        <%# Newsletter Signup %>
        <div class="bg-gradient-to-r from-indigo-600 to-blue-500 rounded-lg shadow-sm p-6 text-white">
          <h3 class="text-lg font-medium mb-2">Subscribe to our Newsletter</h3>
          <p class="text-indigo-100 text-sm mb-4">Get the latest posts delivered right to your inbox.</p>
          <form class="space-y-3">
            <input type="email" placeholder="Your email address" class="w-full px-3 py-2 text-gray-900 placeholder-gray-500 border border-transparent rounded-md focus:outline-none focus:ring-2 focus:ring-white focus:border-transparent sm:text-sm">
            <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-indigo-600 bg-white hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white">
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Add loading indicator for infinite scroll (hidden by default) %>
<%= render 'shared/loading_indicator', hidden: true, id: 'posts-loading', message: 'Loading more posts...' %>

<%# Add styles for line clamping and animations %>
<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  @keyframes fadeIn {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
</style>
