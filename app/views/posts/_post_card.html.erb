<%# _post.html.erb - Individual post card for grid listing %>
<%= link_to post, class: "group bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow duration-200" do %>
  <% if post.cover_image.attached? %>
    <div class="aspect-w-16 aspect-h-9 overflow-hidden">
      <%= image_tag post.cover_image.variant(resize_to_fill: [400, 225]), 
          class: "w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300 ease-out" %>
    </div>
  <% elsif post.gallery_images.attached? && post.gallery_images.first.present? %>
    <div class="aspect-w-16 aspect-h-9 overflow-hidden">
      <%= image_tag post.gallery_images.first.variant(resize_to_fill: [400, 225]), 
          class: "w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300 ease-out" %>
    </div>
  <% else %>
    <div class="aspect-w-16 aspect-h-9 bg-gradient-to-r from-gray-400 to-gray-600"></div>
  <% end %>
  
  <div class="p-4">
    <div class="flex items-center justify-between mb-2">
      <% if post.category.present? %>
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium" 
              style="background-color: <%= post.category.color || '#6366F1' %>20; color: <%= post.category.color || '#6366F1' %>;">
          <%= post.category.name %>
        </span>
      <% end %>
      <span class="text-xs text-gray-500"><%= time_ago_in_words(post.created_at) %> ago</span>
    </div>
    
    <h3 class="font-bold text-gray-900 group-hover:text-blue-600 line-clamp-2 mb-2">
      <%= post.title %>
    </h3>
    
    <p class="text-sm text-gray-600 line-clamp-2 mb-3">
      <%= strip_tags(post.body.to_s) %>
    </p>
    
    <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
      <div class="flex items-center text-xs text-gray-500">
        <% if post.user.present? %>
          <span>By <%= post.user.respond_to?(:name) ? post.user.name : "Staff" %></span>
        <% end %>
        
        <% if post.comments_count.present? && post.comments_count > 0 %>
          <span class="flex items-center ml-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            <%= post.comments_count %>
          </span>
          <% end %>
      </div>
      
      <span class="inline-flex items-center text-xs font-medium text-blue-600">
        Read more
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-1" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </span>
    </div>
  </div>
<% end %>