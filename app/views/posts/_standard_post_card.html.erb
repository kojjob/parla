<%# Standard Post Card - Medium sized card for grid layouts %>
<article class="bg-white overflow-hidden rounded-xl shadow-md transition-all duration-300 hover:shadow-lg hover:translate-y-[-2px] border border-gray-100 h-full">
  <a href="<%= post_path(post) %>" class="block group h-full">
    <header class="relative">
      <div class="relative h-48 overflow-hidden">
        <% if post.cover_image.attached? %>
          <%= image_tag post.cover_image.variant(resize_to_fill: [400, 300]), 
              class: "w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300",
              alt: post.title,
              loading: "lazy" %>
        <% elsif post.gallery_images.attached? && post.gallery_images.first.present? %>
          <%= image_tag post.gallery_images.first.variant(resize_to_fill: [400, 300]), 
              class: "w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300",
              alt: post.title,
              loading: "lazy" %>
        <% else %>
          <div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        <% end %>
        
        <% if post.category.present? %>
          <div class="absolute bottom-3 left-3">
            <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium text-white uppercase" style="background-color: <%= post.category.color || '#3b82f6' %>">
              <%= post.category.name %>
            </span>
          </div>
        <% end %>
        
        <% if post.gallery_images.attached? && post.gallery_images.count > 1 %>
          <div class="absolute bottom-3 right-3 bg-black bg-opacity-60 rounded-full p-1.5" title="<%= pluralize(post.gallery_images.count, 'image') %> in gallery">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        <% end %>
      </div>
    </header>
    
    <div class="p-5">
      <div class="flex justify-between items-start mb-2">
        <h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors duration-200 line-clamp-2"><%= post.title %></h3>
        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 whitespace-nowrap ml-2">
          <%= time_ago_in_words(post.created_at) %> ago
        </span>
      </div>
      
      <p class="mt-2 text-gray-500 text-sm line-clamp-3"><%= strip_tags(post.body.to_s) %></p>
      
      <footer class="mt-4 pt-3 border-t border-gray-100 flex justify-between items-center">
        <div class="text-xs text-gray-500">
          <% if post.user.present? %>
            By <%= post.user.respond_to?(:name) ? post.user.name : "Staff" %>
          <% end %>
          
          <% if post.respond_to?(:comments_count) && post.comments_count.present? && post.comments_count > 0 %>
            <span class="mx-1">•</span>
            <span><%= pluralize(post.comments_count, 'comment') %></span>
          <% end %>
        </div>
        
        <div class="text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center">
          Read more
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        </div>
      </footer>
    </div>
  </a>
</article>
