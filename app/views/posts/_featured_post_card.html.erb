<%# Featured Post Card - Large card for main featured posts %>
<article class="relative overflow-hidden rounded-lg bg-white shadow-lg transition-all duration-300 hover:shadow-xl hover:translate-y-[-2px] h-full">
  <a href="<%= post_path(post) %>" class="block group h-full">
    <div class="relative h-96 overflow-hidden">
      <% if post.cover_image.attached? %>
        <%= image_tag post.cover_image.variant(resize_to_fill: [800, 600]), 
            class: "w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300",
            alt: post.title,
            loading: "lazy" %>
      <% else %>
        <div class="w-full h-full bg-gradient-to-br from-blue-500 to-indigo-600"></div>
      <% end %>
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/40 to-transparent"></div>

      <div class="absolute bottom-0 left-0 p-6 text-white">
        <% if post.category.present? %>
          <span class="inline-block px-2 py-1 text-xs font-medium rounded bg-blue-600 text-white mb-3">
            <%= post.category.name %>
          </span>
        <% end %>
        <h2 class="text-2xl font-bold leading-tight mb-2 group-hover:underline"><%= post.title %></h2>
        <p class="text-sm text-gray-200 line-clamp-2"><%= strip_tags(post.body.to_s).truncate(150) %></p>

        <footer class="flex items-center mt-4 text-sm">
          <span class="text-gray-300"><%= time_ago_in_words(post.created_at) %> ago</span>
          <% if post.user.present? %>
            <span class="mx-2">•</span>
            <span class="text-gray-300">By <%= post.user.respond_to?(:name) ? post.user.name : "Staff" %></span>
          <% end %>
          <% if post.respond_to?(:comments_count) && post.comments_count.present? && post.comments_count > 0 %>
            <span class="mx-2">•</span>
            <span class="text-gray-300"><%= pluralize(post.comments_count, 'comment') %></span>
          <% end %>
        </footer>
      </div>
    </div>
  </a>
</article>
