<div id="<%= dom_id post %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= post.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Body:</strong>
    <%= post.body %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Author:</strong>
    <%= post.author&.name || 'Anonymous' %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Published at:</strong>
    <%= post.published_at %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Tags:</strong>
    <%= post.tags %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Cover image url:</strong>
    <%= post.cover_image_url %>
  </div>
</div>
