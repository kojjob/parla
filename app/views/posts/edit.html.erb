<% content_for :title, "Edit Post: #{@post.title}" %>

<div class="container mx-auto px-4 sx:px-6 lg:px-8 py-8">
  <div class="max-w-7xl mx-auto">
    <!-- Breadcrumbs -->
    <nav class="mb-6 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2">
        <li>
          <%= link_to "Home", root_path, class: "text-gray-500 hover:text-gray-700" %>
        </li>
        <li class="flex items-center">
          <svg class="h-4 w-4 text-gray-400" viewBox="0 0 16 16" fill="currentColor">
            <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
          </svg>
          <%= link_to "Posts", posts_path, class: "ml-2 text-gray-500 hover:text-gray-700" %>
        </li>
        <li class="flex items-center">
          <svg class="h-4 w-4 text-gray-400" viewBox="0 0 16 16" fill="currentColor">
            <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
          </svg>
          <%= link_to @post.title, post_path(@post), class: "ml-2 text-gray-500 hover:text-gray-700 truncate max-w-[150px] sm:max-w-xs" %>
        </li>
        <li class="flex items-center">
          <svg class="h-4 w-4 text-gray-400" viewBox="0 0 16 16" fill="currentColor">
            <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
          </svg>
          <span class="ml-2 text-gray-900 font-medium">Edit</span>
        </li>
      </ol>
    </nav>

    <!-- Page header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <h1 class="text-3xl font-bold text-gray-900">Edit Post</h1>
        
        <!-- Post status indicator -->
        <% if @post.respond_to?(:published) && @post.published? %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
            <span class="h-2 w-2 mr-1.5 rounded-full bg-green-500"></span>
            Published
          </span>
        <% else %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
            <span class="h-2 w-2 mr-1.5 rounded-full bg-yellow-500"></span>
            Draft
          </span>
        <% end %>
      </div>
      <p class="mt-2 text-sm text-gray-600">Last updated: <%= @post.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
    </div>

    <!-- Card container for the form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <%= render 'form', post: @post %>
    </div>

    <!-- Danger zone -->
    <div class="mt-10">
      <h2 class="text-lg font-medium text-gray-900 mb-4">Danger Zone</h2>
      <div class="bg-red-50 rounded-lg border border-red-200 p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">Delete this post</h3>
            <div class="mt-2 text-sm text-red-700">
              <p>Once you delete a post, there is no going back. Please be certain.</p>
            </div>
            <div class="mt-4">
              <%= button_to @post, method: :delete, class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500", data: { turbo_confirm: "Are you sure you want to delete this post?" } do %>
                <svg class="-ml-0.5 mr-2 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                Delete Post
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>