<%= turbo_stream.update "notifications-list" do %>
  <% @notifications = current_user.notifications.order(created_at: :desc).limit(20) %>
  <% if @notifications.any? %>
    <% @notifications.each do |notification| %>
      <%= render "notification", notification: notification %>
    <% end %>
  <% else %>
    <div class="p-6 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
      </svg>
      <h3 class="text-lg font-medium text-gray-900">No notifications</h3>
      <p class="mt-2 text-sm text-gray-500">You don't have any notifications yet.</p>
    </div>
  <% end %>
<% end %>

<%= turbo_stream.update "notifications-dropdown-list" do %>
  <% if current_user.notifications.exists? %>
    <% current_user.notifications.order(created_at: :desc).limit(5).each do |notification| %>
      <%= link_to notification_path(notification), class: "notification-item block px-4 py-3 hover:bg-gray-50 bg-white", data: { turbo_method: :get } do %>
        <div class="flex items-start">
          <div class="flex-shrink-0 mr-3">
            <% if notification.actor.avatar.attached? %>
              <%= image_tag notification.actor.avatar, class: "h-8 w-8 rounded-full object-cover" %>
            <% else %>
              <div class="h-8 w-8 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center text-white">
                <% if notification.actor.name.present? %>
                  <span class="text-xs font-medium"><%= notification.actor.name[0].upcase %></span>
                <% else %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                <% end %>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-gray-900 truncate">
              <span class="font-medium"><%= notification.actor.name %></span>
              <%= notification_message(notification) %>
            </p>
            <p class="text-xs text-gray-500 mt-1"><%= time_ago_in_words(notification.created_at) %> ago</p>
          </div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <div class="px-4 py-6 text-center text-sm text-gray-500">
      No notifications yet
    </div>
  <% end %>
<% end %>

<%= turbo_stream.update "notifications-badge" do %>
  <!-- Empty content to remove the badge -->
<% end %>
