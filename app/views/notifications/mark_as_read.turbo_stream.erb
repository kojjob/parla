<%= turbo_stream.replace dom_id(@notification) do %>
  <%= render "notification", notification: @notification %>
<% end %>

<% if unread_notifications_count == 0 %>
  <%= turbo_stream.update "notifications-badge" do %>
    <!-- Empty content to remove the badge -->
  <% end %>
<% else %>
  <%= turbo_stream.update "notifications-badge" do %>
    <span class="absolute top-0 right-0 block h-4 w-4 rounded-full bg-red-500 text-white text-xs font-bold flex items-center justify-center">
      <%= unread_notifications_count > 9 ? '9+' : unread_notifications_count %>
    </span>
  <% end %>
<% end %>

<%= turbo_stream.update "notifications-dropdown-list" do %>
  <% if current_user.notifications.exists? %>
    <% current_user.notifications.order(created_at: :desc).limit(5).each do |notification| %>
      <%= link_to notification_path(notification), class: "notification-item block px-4 py-3 hover:bg-gray-50 #{notification.read? ? 'bg-white' : 'bg-blue-50'}", data: { turbo_method: :get } do %>
        <div class="flex items-start">
          <div class="flex-shrink-0 mr-3">
            <% if notification.actor.avatar.attached? %>
              <%= image_tag notification.actor.avatar, class: "h-8 w-8 rounded-full object-cover" %>
            <% else %>
              <div class="h-8 w-8 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center text-white">
                <% if notification.actor.name.present? %>
                  <span class="text-xs font-medium"><%= notification.actor.name[0].upcase %></span>
                <% else %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                <% end %>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-gray-900 truncate">
              <span class="font-medium"><%= notification.actor.name %></span>
              <%= notification_message(notification) %>
            </p>
            <p class="text-xs text-gray-500 mt-1"><%= time_ago_in_words(notification.created_at) %> ago</p>
          </div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <div class="px-4 py-6 text-center text-sm text-gray-500">
      No notifications yet
    </div>
  <% end %>
<% end %>
