<div id="<%= dom_id(comment) %>" class="reply-container pl-4 border-l-2 border-gray-200">
  <div class="flex">
    <div class="flex-shrink-0 mr-3">
      <% if comment.user.avatar.attached? %>
        <%= image_tag comment.user.avatar, class: "h-8 w-8 rounded-full object-cover" %>
      <% else %>
        <div class="h-8 w-8 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center text-white">
          <% if comment.user.name.present? %>
            <span class="text-xs font-medium"><%= comment.user.name[0].upcase %></span>
          <% else %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="flex-1">
      <div class="flex items-center justify-between">
        <div>
          <h4 class="text-xs font-medium text-gray-900">
            <%= comment.user.name %>
          </h4>
          <time datetime="<%= comment.created_at.strftime("%Y-%m-%d") %>" class="text-xs text-gray-500">
            <%= comment.created_at.strftime("%b %d, %Y at %I:%M %p") %>
          </time>
        </div>
      </div>

      <div class="mt-2 reply-content">
        <% if comment.content_type == 'rich' && comment.has_rich_content? %>
          <%= comment.rich_content %>
        <% elsif comment.content.present? %>
          <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= comment.content %></p>
        <% end %>

        <% if comment.has_image? %>
          <div class="mt-2">
            <%= image_tag comment.image, class: "rounded-lg max-h-64 max-w-full" %>
          </div>
        <% end %>

        <% if comment.has_video? %>
          <div class="mt-2">
            <video controls class="rounded-lg max-w-full">
              <source src="<%= url_for(comment.video) %>" type="<%= comment.video.content_type %>">
              Your browser does not support the video tag.
            </video>
          </div>
        <% end %>

        <% if comment.has_gif? %>
          <div class="mt-2">
            <%= image_tag comment.gif, class: "rounded-lg max-w-full" %>
          </div>
        <% end %>
      </div>

      <div class="mt-2 flex items-center space-x-3">
        <%= button_to like_comment_path(comment), method: :post, class: "text-gray-500 hover:text-gray-700 text-xs flex items-center" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 7.933a4 4 0 00-.8 2.4z" />
          </svg>
          <span><%= comment.likes_count %></span>
        <% end %>

        <% if can_moderate_comment?(comment) %>
          <%= link_to edit_comment_path(comment), class: "text-gray-500 hover:text-gray-700 text-xs flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
            Edit
          <% end %>

          <%= button_to comment_path(comment), method: :delete, class: "text-gray-500 hover:text-red-600 text-xs flex items-center", data: { turbo_confirm: "Are you sure you want to delete this reply?" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            Delete
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
