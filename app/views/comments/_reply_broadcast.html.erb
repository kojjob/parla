<div id="<%= dom_id(comment) %>" class="bg-gray-50 p-3 rounded-lg border border-gray-100 reply-container">
  <div class="flex">
    <!-- User avatar -->
    <div class="flex-shrink-0 mr-3">
      <% if comment.user.avatar.attached? %>
        <%= image_tag comment.user.avatar, class: "h-8 w-8 rounded-full object-cover" %>
      <% else %>
        <div class="h-8 w-8 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center text-white">
          <% if comment.user.name.present? %>
            <span class="text-xs font-medium"><%= comment.user.name[0].upcase %></span>
          <% else %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>
    
    <!-- Reply content -->
    <div class="flex-1">
      <div class="flex items-center justify-between mb-1">
        <div>
          <h4 class="text-sm font-medium text-gray-900"><%= comment.user.name %></h4>
          <p class="text-xs text-gray-500"><%= time_ago_in_words(comment.created_at) %> ago</p>
        </div>
      </div>
      
      <!-- Reply text content -->
      <% if comment.content.present? %>
        <div class="prose prose-sm max-w-none text-gray-700 mb-2">
          <%= simple_format(comment.content) %>
        </div>
      <% end %>
      
      <!-- Rich content -->
      <% if comment.has_rich_content? %>
        <div class="prose prose-sm max-w-none text-gray-700 mb-2">
          <%= comment.rich_content %>
        </div>
      <% end %>
      
      <!-- Image attachment -->
      <% if comment.image.attached? %>
        <div class="mt-2 mb-2">
          <%= image_tag comment.image, class: "rounded-lg max-h-48 w-auto" %>
        </div>
      <% end %>
      
      <!-- Video attachment -->
      <% if comment.video.attached? %>
        <div class="mt-2 mb-2">
          <video controls class="rounded-lg max-h-48 w-auto">
            <source src="<%= rails_blob_path(comment.video) %>" type="<%= comment.video.content_type %>">
            Your browser does not support the video tag.
          </video>
        </div>
      <% end %>
      
      <!-- GIF attachment -->
      <% if comment.gif.attached? %>
        <div class="mt-2 mb-2">
          <%= image_tag comment.gif, class: "rounded-lg max-h-48 w-auto" %>
        </div>
      <% end %>
      
      <!-- Reply actions -->
      <div class="mt-2 flex items-center space-x-3">
        <%= button_to like_comment_path(comment), method: :post, class: "text-gray-500 hover:text-gray-700 text-xs flex items-center" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 7.933a4 4 0 00-.8 2.4z" />
          </svg>
          <span><%= comment.likes_count %></span>
        <% end %>
      </div>
    </div>
  </div>
</div>
