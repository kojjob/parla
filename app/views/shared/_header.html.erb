<header class="bg-white shadow-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <!-- Logo and primary navigation -->
      <div class="flex">
        <!-- Logo -->
        <div class="flex-shrink-0 flex items-center">
          <%= link_to root_path, class: "flex items-center" do %>
            <svg class="h-8 w-8 text-pink-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M16.24 7.76a6 6 0 0 1 0 8.49m-8.48-.01a6 6 0 0 1 0-8.49m11.31-2.82a10 10 0 0 1 0 14.14m-14.14 0a10 10 0 0 1 0-14.14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span class="ml-2 text-2xl font-bold text-gray-900">Parla</span>
          <% end %>
        </div>

        <!-- Desktop Navigation -->
        <nav class="hidden sm:ml-8 sm:flex sm:space-x-8">
          <%= link_to "Home", root_path, class: "#{current_page?(root_path) ? 'border-pink-500 text-gray-900' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>

          <%= link_to "Posts", posts_path, class: "#{current_page?(posts_path) ? 'border-pink-500 text-gray-900' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>

          <%= link_to "Categories", categories_path, class: "#{current_page?(categories_path) ? 'border-pink-500 text-gray-900' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>

          <%= link_to "Tags", tags_posts_path, class: "#{current_page?(tags_posts_path) ? 'border-pink-500 text-gray-900' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>

          <%= link_to "About", "#", class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>
        </nav>
      </div>

      <!-- Right side buttons and search -->
      <div class="flex items-center">
        <!-- Search Button -->
        <button type="button" class="p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none">
          <span class="sr-only">Search</span>
          <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>

        <!-- User menu (if logged in) -->
        <% if defined?(current_user) && current_user %>
          <!-- Notifications dropdown -->
          <div class="ml-3 relative" data-controller="notifications">
            <div>
              <button type="button" class="p-1 rounded-full text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500 relative" data-action="click->notifications#toggle">
                <span class="sr-only">View notifications</span>
                <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <span id="notifications-badge">
                  <% if unread_notifications_count && unread_notifications_count > 0 %>
                    <span class="absolute top-0 right-0 block h-4 w-4 rounded-full bg-red-500 text-white text-xs font-bold flex items-center justify-center">
                      <%= unread_notifications_count > 9 ? '9+' : unread_notifications_count %>
                    </span>
                  <% end %>
                </span>
              </button>
            </div>

            <!-- Notifications dropdown menu -->
            <div class="hidden origin-top-right absolute right-0 mt-2 w-80 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 focus:outline-none divide-y divide-gray-100 z-50" data-notifications-target="dropdown" role="menu">
              <!-- Header section -->
              <div class="px-4 py-3 flex items-center justify-between">
                <p class="text-sm font-medium text-gray-900">Notifications</p>
                <% if current_user.notifications.unread.exists? %>
                  <%= button_to mark_all_as_read_notifications_path, method: :post, class: "text-xs text-indigo-600 hover:text-indigo-800", data: { turbo: true, action: "click->notifications#markAllAsRead" } do %>
                    Mark all as read
                  <% end %>
                <% end %>
              </div>

              <!-- Notifications list -->
              <div class="max-h-72 overflow-y-auto" id="notifications-dropdown-list">
                <% if current_user.notifications.exists? %>
                  <% current_user.notifications.order(created_at: :desc).limit(5).each do |notification| %>
                    <%= link_to notification_path(notification), class: "notification-item block px-4 py-3 hover:bg-gray-50 #{notification.read? ? 'bg-white' : 'bg-blue-50'}", data: { turbo_method: :get, action: "click->notifications#viewNotification" } do %>
                      <div class="flex items-start">
                        <div class="flex-shrink-0 mr-3">
                          <% if notification.actor.avatar.attached? %>
                            <%= image_tag notification.actor.avatar, class: "h-8 w-8 rounded-full object-cover" %>
                          <% else %>
                            <div class="h-8 w-8 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center text-white">
                              <% if notification.actor.name.present? %>
                                <span class="text-xs font-medium"><%= notification.actor.name[0].upcase %></span>
                              <% else %>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                              <% end %>
                            </div>
                          <% end %>
                        </div>
                        <div class="flex-1 min-w-0">
                          <p class="text-sm text-gray-900 truncate">
                            <span class="font-medium"><%= notification.actor.name %></span>
                            <%= notification_message(notification) %>
                          </p>
                          <p class="text-xs text-gray-500 mt-1"><%= time_ago_in_words(notification.created_at) %> ago</p>
                        </div>
                      </div>
                    <% end %>
                  <% end %>
                <% else %>
                  <div class="px-4 py-6 text-center text-sm text-gray-500">
                    No notifications yet
                  </div>
                <% end %>
              </div>

              <!-- Footer section -->
              <div class="py-2">
                <%= link_to notifications_path, class: "block px-4 py-2 text-sm text-center text-indigo-600 hover:text-indigo-800", data: { turbo_method: :get, action: "click->notifications#viewAll" } do %>
                  View all notifications
                <% end %>
              </div>
            </div>
          </div>

          <!-- User profile dropdown -->
          <div class="ml-3 relative">
            <div>
              <button type="button" class="flex items-center text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500" id="user-menu-button">
                <span class="sr-only">Open user menu</span>
                <% if current_user.respond_to?(:avatar) && current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, class: "h-8 w-8 rounded-full border-2 border-white shadow-sm" %>
                <% else %>
                  <div class="h-8 w-8 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center text-white shadow-sm border-2 border-white">
                    <% if current_user.respond_to?(:name) && current_user.name.present? %>
                      <span class="text-sm font-medium"><%= current_user.name[0].upcase %></span>
                    <% else %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                      </svg>
                    <% end %>
                  </div>
                <% end %>
                <svg class="ml-1 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </button>
            </div>
            <!-- User dropdown menu -->
            <div class="hidden origin-top-right absolute right-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 focus:outline-none divide-y divide-gray-100 z-50" id="user-menu-dropdown" role="menu">
              <!-- User info section -->
              <div class="px-4 py-3">
                <p class="text-sm font-medium text-gray-900 truncate"><%= current_user.respond_to?(:name) ? current_user.name : "User" %></p>
                <p class="text-xs text-gray-500 truncate"><%= current_user.respond_to?(:email) ? current_user.email : "" %></p>
              </div>

              <!-- Main menu items -->
              <div class="py-1">
                <%= link_to notifications_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", role: "menuitem" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-gray-500" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" />
                  </svg>
                  Notifications
                  <% if unread_notifications_count && unread_notifications_count > 0 %>
                    <span class="ml-auto bg-red-500 text-white text-xs font-bold px-1.5 py-0.5 rounded-full">
                      <%= unread_notifications_count > 9 ? '9+' : unread_notifications_count %>
                    </span>
                  <% end %>
                <% end %>

                <%= link_to "#", class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", role: "menuitem" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-gray-500" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                  </svg>
                  Your Profile
                <% end %>

                <%= link_to new_post_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", role: "menuitem" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-gray-500" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" />
                  </svg>
                  New Post
                <% end %>

                <%= link_to "#", class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", role: "menuitem" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-gray-500" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
                  </svg>
                  Settings
                <% end %>
              </div>

              <!-- Sign out section -->
              <div class="py-1">
                <% if defined?(destroy_user_session_path) %>
                  <%= button_to destroy_user_session_path, method: :delete, class: "flex w-full items-center px-4 py-2 text-sm text-red-600 hover:bg-gray-100", role: "menuitem" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 001 1h12a1 1 0 001-1V7.414l-5-5H3zm7 5a1 1 0 10-2 0v4.586l-1.293-1.293a1 1 0 10-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L12 12.586V8z" clip-rule="evenodd" />
                    </svg>
                    Sign out
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <!-- Login/Register buttons -->
          <div class="ml-4 flex items-center space-x-3">
            <%= link_to "Log in", defined?(new_user_session_path) ? new_user_session_path : "#", class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>

            <%= link_to "Sign up", defined?(new_user_registration_path) ? new_user_registration_path : "#", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-pink-600 hover:bg-pink-700" %>
          </div>
        <% end %>

        <!-- Mobile menu button -->
        <div class="flex items-center sm:hidden ml-4">
          <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none" id="mobile-menu-button">
            <span class="sr-only">Open main menu</span>
            <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile menu, show/hide based on menu state -->
  <div class="hidden sm:hidden" id="mobile-menu">
    <div class="pt-2 pb-3 space-y-1">
      <%= link_to "Home", root_path, class: "#{current_page?(root_path) ? 'bg-pink-50 border-pink-500 text-pink-700' : 'border-transparent text-gray-600 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-800'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium" %>

      <%= link_to "Posts", posts_path, class: "#{current_page?(posts_path) ? 'bg-pink-50 border-pink-500 text-pink-700' : 'border-transparent text-gray-600 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-800'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium" %>

      <%= link_to "Categories", categories_path, class: "#{current_page?(categories_path) ? 'bg-pink-50 border-pink-500 text-pink-700' : 'border-transparent text-gray-600 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-800'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium" %>

      <%= link_to "Tags", tags_posts_path, class: "#{current_page?(tags_posts_path) ? 'bg-pink-50 border-pink-500 text-pink-700' : 'border-transparent text-gray-600 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-800'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium" %>

      <%= link_to "About", "#", class: "border-transparent text-gray-600 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-800 block pl-3 pr-4 py-2 border-l-4 text-base font-medium" %>
    </div>

    <% if defined?(current_user) && current_user %>
      <div class="pt-4 pb-3 border-t border-gray-200">
        <div class="flex items-center px-4">
          <div class="flex-shrink-0">
            <% if current_user.respond_to?(:avatar) && current_user.avatar.attached? %>
              <%= image_tag current_user.avatar, class: "h-10 w-10 rounded-full" %>
            <% else %>
              <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                </svg>
              </div>
            <% end %>
          </div>
          <div class="ml-3">
            <div class="text-base font-medium text-gray-800"><%= current_user.respond_to?(:name) ? current_user.name : "User" %></div>
            <div class="text-sm font-medium text-gray-500"><%= current_user.respond_to?(:email) ? current_user.email : "" %></div>
          </div>
        </div>
        <div class="mt-3 space-y-1">
          <%= link_to notifications_path, class: "flex items-center px-4 py-2 text-base font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" />
            </svg>
            Notifications
            <% if unread_notifications_count && unread_notifications_count > 0 %>
              <span class="ml-auto bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full">
                <%= unread_notifications_count > 9 ? '9+' : unread_notifications_count %>
              </span>
            <% end %>
          <% end %>

          <%= link_to "#", class: "flex items-center px-4 py-2 text-base font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
            </svg>
            Your Profile
          <% end %>

          <%= link_to new_post_path, class: "flex items-center px-4 py-2 text-base font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" />
            </svg>
            New Post
          <% end %>

          <%= link_to "#", class: "flex items-center px-4 py-2 text-base font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
            </svg>
            Settings
          <% end %>

          <% if defined?(destroy_user_session_path) %>
            <%= button_to destroy_user_session_path, method: :delete, class: "flex w-full items-center px-4 py-2 text-base font-medium text-red-600 hover:bg-gray-100" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 001 1h12a1 1 0 001-1V7.414l-5-5H3zm7 5a1 1 0 10-2 0v4.586l-1.293-1.293a1 1 0 10-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L12 12.586V8z" clip-rule="evenodd" />
              </svg>
              Sign out
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</header>

<script>
  // Initialize dropdown functionality immediately and also on DOMContentLoaded
  function initializeDropdowns() {
    // User menu toggle
    const userMenuButton = document.getElementById('user-menu-button');
    const userMenuDropdown = document.getElementById('user-menu-dropdown');

    if (userMenuButton && userMenuDropdown) {
      // Remove any existing event listeners (to prevent duplicates)
      userMenuButton.removeEventListener('click', toggleUserMenu);

      // Add click event listener
      userMenuButton.addEventListener('click', toggleUserMenu);

      // Function to toggle user menu
      function toggleUserMenu(event) {
        event.stopPropagation(); // Prevent event from bubbling up
        userMenuDropdown.classList.toggle('hidden');

        // Hide notifications dropdown when opening user menu
        if (notificationsDropdown) {
          notificationsDropdown.classList.add('hidden');
        }
      }
    }

    // User menu dropdown is handled by the code above
    // Notifications dropdown is now handled by the Stimulus controller

    // Notifications dropdown click handling is now managed by the Stimulus controller

    // Close the dropdowns when clicking outside
    document.addEventListener('click', function(event) {
      // Close user menu dropdown
      if (userMenuButton && userMenuDropdown &&
          !userMenuButton.contains(event.target) &&
          !userMenuDropdown.contains(event.target)) {
        userMenuDropdown.classList.add('hidden');
      }

      // Notifications dropdown click outside handling is now managed by the Stimulus controller
    });

    // Mobile menu toggle
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuButton && mobileMenu) {
      // Remove any existing event listeners (to prevent duplicates)
      mobileMenuButton.removeEventListener('click', toggleMobileMenu);

      // Add click event listener
      mobileMenuButton.addEventListener('click', toggleMobileMenu);

      // Function to toggle mobile menu
      function toggleMobileMenu() {
        mobileMenu.classList.toggle('hidden');

        // Toggle between hamburger and X icon
        const hamburgerIcon = mobileMenuButton.querySelector('svg:first-child');
        const closeIcon = mobileMenuButton.querySelector('svg:last-child');

        if (hamburgerIcon && closeIcon) {
          hamburgerIcon.classList.toggle('hidden');
          closeIcon.classList.toggle('hidden');
        }
      }
    }
  }

  // Run immediately
  initializeDropdowns();

  // Also run on DOMContentLoaded to ensure it works with Turbo
  document.addEventListener('DOMContentLoaded', initializeDropdowns);

  // Support for Turbo Drive navigation
  document.addEventListener('turbo:load', initializeDropdowns);
  document.addEventListener('turbo:render', initializeDropdowns);
</script>